Скрипт создан для Delta Executor]]
infoText.TextColor3 = Color3.fromRGB(200, 200, 220)
infoText.TextSize = 12
infoText.Font = Enum.Font.Gotham
infoText.TextWrapped = true
infoText.TextXAlignment = Enum.TextXAlignment.Left
infoText.Parent = infoTab

local infoCorner = Instance.new("UICorner")
infoCorner.CornerRadius = UDim.new(0, 8)
infoCorner.Parent = infoText

-- АКТИВАЦИЯ ПЕРВОЙ ВКЛАДКИ
tabs["📍 ТП"].button.MouseButton1Click:Fire()

-- ЗАКРЫТИЕ
closeButton.MouseButton1Click:Connect(function()
    if flying then disableFly() end
    if noclipEnabled then disableNoclip() end
    if infiniteJump then disableInfiniteJump() end
    if hitboxExpansion then disableHitboxExpansion() end
    screenGui:Destroy()
end)

print("✅ Delta Hub v1.1 загружен! NoClip теперь работает!")
