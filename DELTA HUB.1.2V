-- Вкладка MOVEMENT
local moveTab = createTab("🏃 Движение", 3)

createToggle(moveTab, "✈️ Режим полёта (WASD + Space/Ctrl)", function() return flying end, function(v)
    if v then enableFly() else disableFly() end
end)

createSlider(moveTab, "🚀 Скорость полёта", 20, 300, function() return flySpeed end, function(v)
    flySpeed = v
end)

createToggle(moveTab, "🚪 NoClip (проход сквозь стены)", function() return noclipEnabled end, function(v)
    if v then enableNoclip() else disableNoclip() end
end)

createSlider(moveTab, "🏃 Скорость ходьбы", 16, 250, 
    function() 
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("Humanoid") then
            return char.Humanoid.WalkSpeed
        end
        return 16
    end,
    function(v) setWalkSpeed(v) end
)

createSlider(moveTab, "🦘 Сила прыжка", 50, 300,
    function()
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("Humanoid") then
            return char.Humanoid.JumpPower
        end
        return 50
    end,
    function(v) setJumpPower(v) end
)

createButton(moveTab, "🔄 Сбросить скорость (16)", Color3.fromRGB(70, 70, 80), function()
    setWalkSpeed(16)
end)

createToggle(moveTab, "🔄 Бесконечные прыжки", function() return infiniteJump end, function(v)
    if v then enableInfiniteJump() else disableInfiniteJump() end
end)

