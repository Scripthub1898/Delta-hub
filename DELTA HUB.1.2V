infoText.TextColor3 = Color3.fromRGB(200, 200, 220)
infoText.TextSize = 12
infoText.Font = Enum.Font.Gotham
infoText.TextWrapped = true
infoText.TextXAlignment = Enum.TextXAlignment.Left
infoText.Parent = infoTab

local infoCorner = Instance.new("UICorner")
infoCorner.CornerRadius = UDim.new(0, 8)
infoCorner.Parent = infoText

-- ============ ПЕРЕТАСКИВАНИЕ ОКНА ============
local isDragging = false
local dragStart = nil
local startPos = nil

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
    end
end)

titleBar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if isDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        toggleButton.Position = UDim2.new(mainFrame.Position.X.Scale, mainFrame.Position.X.Offset + mainFrame.Size.X.Offset + 10, mainFrame.Position.Y.Scale, mainFrame.Position.Y.Offset + mainFrame.Size.Y.Offset - 60)
    end
end)

local function updateButtonPos()
    toggleButton.Position = UDim2.new(mainFrame.Position.X.Scale, mainFrame.Position.X.Offset + mainFrame.Size.X.Offset + 10, mainFrame.Position.Y.Scale, mainFrame.Position.Y.Offset + mainFrame.Size.Y.Offset - 60)
end

mainFrame:GetPropertyChangedSignal("Position"):Connect(updateButtonPos)
mainFrame:GetPropertyChangedSignal("Size"):Connect(updateButtonPos)

-- ============ ГОРЯЧИЕ КЛАВИШИ ============
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.F5 then
        guiVisible = not guiVisible
        mainFrame.Visible = guiVisible
        toggleButton.Visible = guiVisible
    end
end)

-- ============ КНОПКА-КРУГ ============
toggleButton.MouseButton1Click:Connect(function()
    mainFrame.Visible = not mainFrame.Visible
    guiVisible = mainFrame.Visible
end)

toggleButton.MouseEnter:Connect(function()
    TweenService:Create(toggleButton, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Size = UDim2.new(0, 55, 0, 55)}):Play()
end)

toggleButton.MouseLeave:Connect(function()
    TweenService:Create(toggleButton, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Size = UDim2.new(0, 50, 0, 50)}):Play()
end)

-- ============ ЗАКРЫТИЕ ============
local function closeGui()
    pcall(function()
        if flying then disableFly() end
        if noclipEnabled then disableNoclip() end
        if infiniteJump then disableInfiniteJump() end
        if hitboxRemoved then restoreHitbox() end
        if hitboxConnection then hitboxConnection:Disconnect() end
        if hitboxCharConnection then hitboxCharConnection:Disconnect() end
        if flyConnection then flyConnection:Disconnect() end
        if noclipConnection then noclipConnection:Disconnect() end
        if noclipCharConnection then noclipCharConnection:Disconnect() end
    end)
    
    task.spawn(function()
        task.wait(0.05)
        pcall(function()
            if screenGui and screenGui.Parent then
                screenGui:Destroy()
            end
        end)
    end)
end

closeButton.MouseButton1Click:Connect(closeGui)
minButton.MouseButton1Click:Connect(function()
    mainFrame.Visible = false
    guiVisible = false
end)

-- АКТИВАЦИЯ ПЕРВОЙ ВКЛАДКИ
tabs["📍 ТП"].button.MouseButton1Click:Fire()

print("✅ Delta Hub v1.9 загружен!")
print("🔧 Все утилиты добавлены в отдельную вкладку!")
