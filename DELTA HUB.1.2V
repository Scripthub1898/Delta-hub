infoText.Size = UDim2.new(1, -20, 0, 400)
infoText.Position = UDim2.new(0, 10, 0, 10)
infoText.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
infoText.BackgroundTransparency = 0.3
infoText.Text = [[🔷 Delta Hub v1.9

📊 СТАТИСТИКА:
━━━━━━━━━━━━━━━━━━━━━
✅ Всего строк кода: 3,200+
✅ Функций: 15+
✅ Вкладок: 6

🔧 УТИЛИТЫ (вкладка Утилиты):
━━━━━━━━━━━━━━━━━━━━━
