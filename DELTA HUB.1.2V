local function loadFlyGui()
    if flyGuiLoaded then 
        StarterGui:SetCore("SendNotification", {Title = "Delta Hub", Text = "⚠️ FLY GUI V3 уже загружен!", Duration = 3})
        return 
    end
    flyGuiLoaded = true
    
    local flyScript = [[
        -- FLY GUI V3
