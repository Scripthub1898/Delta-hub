-- НАСТРОЙКИ
local Settings = {
    Mode = "Normal",
    IsActive = false,
    OriginalCameraCFrame = nil,
    FakeCharacter = nil,
    RealBody = nil
}

-- ПОЗИЦИЯ ЗА КАРТОЙ
local FAR_POSITION = Vector3.new(100000, 100000, 100000)

-- СОЗДАНИЕ КЛОНА-ГОЛОГРАММЫ (для управления)
local function CreateHologramClone(originalChar)
    local clone = originalChar:Clone()
    clone.Name = "HologramClone"
    clone.Parent = Workspace
    
    -- Делаем клон полупрозрачным
    for _, part in pairs(clone:GetDescendants()) do
        if part:IsA("BasePart") or part:IsA("MeshPart") then
            part.Transparency = 0.4
            part.Material = Enum.Material.Neon
            part.CanCollide = false
            
            -- Добавляем свечение
            local glow = Instance.new("SelectionBox")
            glow.Name = "GlowEffect"
            glow.Color3 = Color3.fromRGB(0, 200, 255)
            glow.LineThickness = 0.1
            glow.Transparency = 0.5
            glow.Adornee = part
            glow.Parent = part
        end
    end
    
    -- Отключаем скрипты в клоне
    for _, script in pairs(clone:GetDescendants()) do
        if script:IsA("Script") or script:IsA("LocalScript") then
            script:Destroy()
        end
    end
    
    return clone
end

-- ФУНКЦИЯ: Блокировка управления реальным телом
local function DisableRealBody(character)
    local humanoid = character:FindFirstChild("Humanoid")
    if humanoid then
        humanoid.PlatformStand = true
        humanoid.AutoRotate = false
    end
    
    -- Замораживаем все части
    for _, part in pairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Anchored = true
            part.CanCollide = false
        end
    end
end

-- ФУНКЦИЯ: Привязка камеры к голограмме
local function AttachCameraToClone(clone)
    local camera = Workspace.CurrentCamera
    if not camera then return end
    
    -- Сохраняем настройки камеры
    camera.CameraType = Enum.CameraType.Custom
    
    -- Привязываем камеру к голове клона
    local head = clone:FindFirstChild("Head")
    if head then
        camera.CameraSubject = head
    else
        local humanoid = clone:FindFirstChild("Humanoid")
        if humanoid then
            camera.CameraSubject = humanoid
        end
    end
end

-- ОТПРАВКА ТЕЛА ЗА КАРТУ
local function SendBodyFarAway(character)
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return end
    
    Settings.RealBody = character
    
    -- Отправляем тело далеко
    humanoidRootPart.CFrame = CFrame.new(FAR_POSITION)
    
    -- Блокируем управление реальным телом
    DisableRealBody(character)
    
    -- Делаем тело полностью невидимым
    for _, part in pairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Transparency = 1
            part.LocalTransparencyModifier = 1
        end
    end
end

-- СОЗДАНИЕ ГОЛОГРАММЫ ДЛЯ УПРАВЛЕНИЯ
local function CreateControllableHologram(originalChar)
    -- Создаем клон для управления
    local hologram = CreateHologramClone(originalChar)
    
    -- Копируем позицию
    local hrp = originalChar:FindFirstChild("HumanoidRootPart")
    if hrp then
        hologram:SetPrimaryPartCFrame(hrp.CFrame)
    end
    
    -- Привязываем камеру к голограмме
    AttachCameraToClone(hologram)
    
    -- Запускаем синхронизацию управления
    task.spawn(function()
        while Settings.IsActive and hologram and hologram.Parent do
            task.wait()
            
            -- Синхронизируем движение голограммы с управлением игрока
            local userInput = UserInputService:GetKeysPressed()
            
            -- Получаем направление движения от оригинального персонажа
            local originalChar = LocalPlayer.Character
            if originalChar and originalChar:FindFirstChild("Humanoid") then
                local humanoid = originalChar.Humanoid
                local moveDirection = humanoid.MoveDirection
                
                -- Перемещаем голограмму
                local hologramHRP = hologram:FindFirstChild("HumanoidRootPart")
                if hologramHRP and moveDirection.Magnitude > 0 then
                    local speed = humanoid.WalkSpeed
                    local newPos = hologramHRP.Position + (moveDirection * speed * task.wait())
                    hologramHRP.CFrame = CFrame.new(newPos)
                end
            end
        end
    end)
    
    return hologram
end

-- УНИЧТОЖЕНИЕ ГОЛОГРАММЫ
local function DestroyHologram()
    if Settings.FakeCharacter and Settings.FakeCharacter.Parent then
        Settings.FakeCharacter:Destroy()
    end
    Settings.FakeCharacter = nil
end

-- ВЕРНУТЬ ТЕЛО
local function ReturnBody()
    if not Settings.RealBody then return end
    
    local character = LocalPlayer.Character
    if not character then return end
    
    -- Возвращаем тело на спавн
    local spawnLocation = Workspace:FindFirstChild("SpawnLocation")
    local returnPos = spawnLocation and spawnLocation.Position or Vector3.new(0, 10, 0)
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if hrp then
        hrp.CFrame = CFrame.new(returnPos)
        hrp.Anchored = false
    end
    
    -- Восстанавливаем управление
    local humanoid = character:FindFirstChild("Humanoid")
    if humanoid then
        humanoid.PlatformStand = false
        humanoid.AutoRotate = true
    end
    
    -- Возвращаем видимость
    for _, part in pairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Transparency = 0
            part.LocalTransparencyModifier = 0
            part.CanCollide = true
        end
    end
    
    -- Возвращаем камеру
    local camera = Workspace.CurrentCamera
    if camera then
        camera.CameraSubject = humanoid
        camera.CameraType = Enum.CameraType.Custom
    end
    
    Settings.RealBody = nil
end

-- ОСНОВНАЯ ФУНКЦИЯ
local function ToggleInvis()
    local character = LocalPlayer.Character
    if not character then
        print("❌ Персонаж не найден")
        return
    end
    
    Settings.IsActive = not Settings.IsActive
    
    if Settings.IsActive then
        -- АКТИВАЦИЯ
        print("✅ Активация инвиза...")
        
        -- 1. Отправляем тело за карту
        SendBodyFarAway(character)
        
        -- 2. Создаем управляемую голограмму
        local hologram = CreateControllableHologram(character)
        Settings.FakeCharacter = hologram
        
        -- 3. Прячем оригинальное тело
        for _, part in pairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Transparency = 1
                part.LocalTransparencyModifier = 1
            end
        end
        
        print("✅ Голограмма создана! Камера привязана к голограмме")
        
    else
        -- ДЕАКТИВАЦИЯ
        print("❌ Деактивация инвиза...")
        
        -- 1. Возвращаем тело
        ReturnBody()
        
        -- 2. Удаляем голограмму
        DestroyHologram()
        
        print("✅ Инвиз деактивирован")
    end
end

