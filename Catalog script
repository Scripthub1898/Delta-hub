-- ФУНКЦИЯ: Сделать персонажа НЕВИДИМЫМ ДЛЯ ДРУГИХ
local function MakeInvisibleForOthers(character, isInvisible)
    if not character then return end
    
    for _, descendant in pairs(character:GetDescendants()) do
        if descendant:IsA("BasePart") or descendant:IsA("MeshPart") then
            if isInvisible then
                -- Делаем невидимым для других через LocalTransparencyModifier
                descendant.LocalTransparencyModifier = 1
            else
                descendant.LocalTransparencyModifier = 0
            end
        end
    end
    
    -- Если это не локальный игрок, скрываем полностью
    if character ~= LocalPlayer.Character then
        for _, descendant in pairs(character:GetDescendants()) do
            if descendant:IsA("BasePart") then
                descendant.Transparency = isInvisible and 1 or 0
            end
        end
    end
end

-- ФУНКЦИЯ: Сделать ТЕБЯ голограммой (видишь себя полупрозрачным)
local function MakeSelfHologram(character, isHologram)
    if not character or character ~= LocalPlayer.Character then return end
    
    for _, part in pairs(character:GetDescendants()) do
        if part:IsA("BasePart") or part:IsA("MeshPart") then
            if isHologram then
                -- Ты видишь себя как голограмму (полупрозрачную)
                part.Transparency = 0.5
                -- Эффект свечения
                local glow = part:FindFirstChild("HologramGlow")
                if not glow and part:IsA("BasePart") then
                    local newGlow = Instance.new("SelectionBox")
                    newGlow.Name = "HologramGlow"
                    newGlow.Color3 = Color3.fromRGB(0, 200, 255)
                    newGlow.LineThickness = 0.05
                    newGlow.Transparency = 0.7
                    newGlow.Adornee = part
                    newGlow.Parent = part
                end
            else
                part.Transparency = 0
                local glow = part:FindFirstChild("HologramGlow")
                if glow then glow:Destroy() end
            end
        end
    end
end

-- ФУНКЦИЯ: Отправить реальное тело за карту
local function SendBodyFarAway(character)
    if not character then return end
    
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if humanoidRootPart then
        -- Сохраняем оригинальную позицию
        Settings.RealBodyPosition = humanoidRootPart.Position
        
        -- Телепортируем тело ДАЛЕКО за карту
        humanoidRootPart.CFrame = CFrame.new(FAR_POSITION)
        
        -- Замораживаем тело, чтобы оно не падало
        humanoidRootPart.Anchored = true
        
        -- Отключаем управление старым телом
        local humanoid = character:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.PlatformStand = true
        end
        
        -- Делаем тело полностью невидимым для всех
        for _, part in pairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Transparency = 1
                part.CanCollide = false
            end
        end
    end
end

-- ФУНКЦИЯ: Вернуть тело на место
local function ReturnBody()
    local character = LocalPlayer.Character
    if not character then return end
    
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if humanoidRootPart and Settings.RealBodyPosition then
        humanoidRootPart.CFrame = CFrame.new(Settings.RealBodyPosition)
        humanoidRootPart.Anchored = false
        
        local humanoid = character:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.PlatformStand = false
        end
        
        -- Возвращаем видимость
        for _, part in pairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Transparency = 0
                part.CanCollide = true
            end
        end
        
        StatusLabel.Text = "Статус: ТЕЛО ВЕРНУТО\nИнвиз: ❌ ВЫКЛ"
    end
end

-- ОСНОВНАЯ ФУНКЦИЯ АКТИВАЦИИ ИНВИЗА
local function ToggleInvis()
    local character = LocalPlayer.Character
    if not character then 
        StatusLabel.Text = "Статус: ОШИБКА\nПерсонаж не найден!"
        return
    end
    
    Settings.IsActive = not Settings.IsActive
    
    if Settings.IsActive then
        -- АКТИВАЦИЯ ИНВИЗА
        -- 1. Отправляем тело за карту
        SendBodyFarAway(character)
        
        -- 2. Делаем себя голограммой (видим полупрозрачным)
        MakeSelfHologram(character, true)
        
        -- 3. Скрываем себя от других игроков (глобально)
        MakeInvisibleForOthers(character, true)
        
        -- 4. Создаем копию себя на месте (но это не нужно, т.к. ты уже голограмма)
        
        StatusLabel.Text = "Статус: ✅ ИНВИЗ АКТИВЕН\nИнвиз: ✅ ВКЛ\nВидимость для других: НЕВИДИМ\nТы: Голограмма\nТело: ЗА КАРТОЙ"
        ActivateBtn.Text = "🌀 ДЕАКТИВИРОВАТЬ ИНВИЗ"
        ActivateBtn.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
        
        -- Звуковой эффект
        local sound = Instance.new("Sound")
        sound.SoundId = "rbxassetid://9120386437" -- Звук телепортации
        sound.Volume = 0.5
        sound.Parent = character
        sound:Play()
        task.wait(0.5)
        sound:Destroy()
        
    else
        -- ДЕАКТИВАЦИЯ ИНВИЗА
        -- 1. Возвращаем тело
        ReturnBody()
        
        -- 2. Убираем голограмму с себя
        MakeSelfHologram(character, false)
        
        -- 3. Делаем себя видимым для других
        MakeInvisibleForOthers(character, false)
        
        StatusLabel.Text = "Статус: ОЖИДАНИЕ\nИнвиз: ❌ ВЫКЛ\nВидимость для других: ВИДИМ\nТы: Нормальный"
        ActivateBtn.Text = "🌀 АКТИВИРОВАТЬ ИНВИЗ"
        ActivateBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 120)
    end
end

-- ТЕЛЕПОРТ ТЕЛА НА СПАВН (для авто-режима)
local function TeleportToSpawn()
    if not Settings.IsActive then
        StatusLabel.Text = "Статус: СНАЧАЛА АКТИВИРУЙ ИНВИЗ"
        return
    end
    
    local character = LocalPlayer.Character
    if character then
        local spawnLocation = Workspace:FindFirstChild("SpawnLocation")
        if spawnLocation then
            local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
            if humanoidRootPart then
                humanoidRootPart.CFrame = spawnLocation.CFrame
                StatusLabel.Text = "Статус: ТЕЛО ТЕЛЕПОРТИРОВАНО НА СПАВН"
            end
        else
            StatusLabel.Text = "Статус: СПАВН НЕ НАЙДЕН"
        end
    end
end

