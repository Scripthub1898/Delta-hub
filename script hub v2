				game.VirtualInputManager:SendKeyEvent(true, key, false, game)
				task.wait(0.2)
				game.VirtualInputManager:SendKeyEvent(false, key, false, game)
			end)
			task.wait(1) -- delay antar skill
		end
	end)
end

