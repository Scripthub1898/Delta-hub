-- INVIS SYSTEM v2
-- Ты = полупрозрачный клон (видишь только себя)
-- Оригинальное тело далеко за картой (невидимо, неуязвимо)
-- Камера и управление привязаны к клону
-- При выключении инвиза: тело телепортируется к клону

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local Workspace = game:GetService("Workspace")

local player = Players.LocalPlayer
local camera = Workspace.CurrentCamera

-- ========== ПЕРЕМЕННЫЕ ==========
local isInvisible = false
local cloneCharacter = nil
local originalCharacter = nil
local flyEnabled = false
local moveDirection = Vector3.new(0, 0, 0)
local bodyVelocity = nil
local bodyGyro = nil
local originalHumanoid = nil

-- ========== НАСТРОЙКИ ==========
local CONFIG = {
    hideDistance = 1000,              -- Как далеко прятать ориг тело
    flySpeed = 120,                   -- Скорость полёта клона
    cloneTransparency = 0.3,          -- Прозрачность клона (0.3 = полупрозрачный)
    cloneColor = Color3.fromRGB(0, 200, 255), -- Цвет свечения
    toggleKey = Enum.KeyCode.V        -- Клавиша вкл/выкл
}

-- ========== СОХРАНЯЕМ ОРИГИНАЛЬНОГО ПЕРСОНАЖА ==========
originalCharacter = player.Character or player.CharacterAdded:Wait()
originalHumanoid = originalCharacter:WaitForChild("Humanoid")

-- ========== 1. СОЗДАНИЕ КЛОНА (ТЫ) ==========
local function createClone()
    if cloneCharacter then cloneCharacter:Destroy() end
    
    -- Клонируем оригинального персонажа
    cloneCharacter = originalCharacter:Clone()
    cloneCharacter.Name = "PlayerClone_" .. player.Name
    cloneCharacter.Parent = workspace
    
    -- Настройка внешнего вида (полупрозрачный, только для тебя)
    for _, part in ipairs(cloneCharacter:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Transparency = CONFIG.cloneTransparency
            part.CanCollide = true
            part.Material = Enum.Material.Neon
            
            -- Добавляем свечение
            local glow = Instance.new("PointLight")
            glow.Parent = part
            glow.Color = CONFIG.cloneColor
            glow.Intensity = 0.5
            glow.Range = 8
        elseif part:IsA("Humanoid") then
            part.NameDisplayDistance = 0  -- Без имени над головой
            part.BreakJointsOnDeath = false
            part.WalkSpeed = originalHumanoid.WalkSpeed
            part.JumpPower = originalHumanoid.JumpPower
        end
    end
    
    -- Копируем позицию оригинального тела
    local origRoot = originalCharacter:FindFirstChild("HumanoidRootPart")
    local cloneRoot = cloneCharacter:FindFirstChild("HumanoidRootPart")
    if origRoot and cloneRoot then
        cloneRoot.CFrame = origRoot.CFrame
    end
    
    return cloneCharacter
end

-- ========== 2. ПРИВЯЗКА КАМЕРЫ К КЛОНУ ==========
local function attachCameraToClone()
    if not cloneCharacter then return end
    
    local cloneRoot = cloneCharacter:FindFirstChild("HumanoidRootPart")
    if cloneRoot then
        camera.CameraSubject = cloneRoot
        camera.CameraType = Enum.CameraType.Custom
    end
end

-- ========== 3. ЭКИПИРОВКА ОРУЖИЯ В КЛОНА ==========
local function equipWeaponsToClone()
    if not cloneCharacter then return end
    
    -- Копируем всё оружие из инвентаря в клона
    local backpack = player:FindFirstChild("Backpack")
    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") then
                local weaponClone = tool:Clone()
                weaponClone.Parent = cloneCharacter
                
                -- Прикрепляем к руке клона
                local rightHand = cloneCharacter:FindFirstChild("RightHand")
                local handle = weaponClone:FindFirstChild("Handle")
                
                if rightHand and handle then
                    local weld = Instance.new("Weld")
                    weld.Part0 = rightHand
                    weld.Part1 = handle
                    weld.C0 = CFrame.new(0, -1, 0)
                    weld.Parent = weaponClone
                end
                
                -- Делаем оружие таким же полупрозрачным
                for _, part in ipairs(weaponClone:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.Transparency = CONFIG.cloneTransparency
                        part.Material = Enum.Material.Neon
                    end
                end
            end
        end
    end
    
    -- Копируем оружие из рук
    local characterTools = originalCharacter:GetChildren()
    for _, tool in ipairs(characterTools) do
        if tool:IsA("Tool") then
            local weaponClone = tool:Clone()
            weaponClone.Parent = cloneCharacter
            
            local rightHand = cloneCharacter:FindFirstChild("RightHand")
            local handle = weaponClone:FindFirstChild("Handle")
            
            if rightHand and handle then
                local weld = Instance.new("Weld")
                weld.Part0 = rightHand
                weld.Part1 = handle
                weld.C0 = CFrame.new(0, -1, 0)
                weld.Parent = weaponClone
            end
        end
    end
end

-- ========== 4. ПРЯЧЕМ ОРИГИНАЛЬНОЕ ТЕЛО (далеко за картой) ==========
local function hideOriginalBody()
    local origRoot = originalCharacter:FindFirstChild("HumanoidRootPart")
    if not origRoot then return end
    
    -- Сохраняем позицию где стоял клон (на случай если понадобится)
    local cloneRoot = cloneCharacter and cloneCharacter:FindFirstChild("HumanoidRootPart")
    if cloneRoot then
        -- Телепортируем ориг тело далеко за карту
        local farAway = Vector3.new(CONFIG.hideDistance, CONFIG.hideDistance, CONFIG.hideDistance)
        originalCharacter:SetPrimaryPartCFrame(CFrame.new(farAway))
    end
    
    -- Делаем оригинальное тело полностью невидимым
    for _, part in ipairs(originalCharacter:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Transparency = 1
            part.CanCollide = false
        end
    end
    
    -- Отключаем управление оригинальным телом
    if originalHumanoid then
        originalHumanoid.WalkSpeed = 0
        originalHumanoid.JumpPower = 0
        originalHumanoid.AutoRotate = false
    end
end

-- ========== 5. СИСТЕМА ПОЛЁТА ДЛЯ КЛОНА ==========
local function enableFlightForClone()
    local cloneRoot = cloneCharacter:FindFirstChild("HumanoidRootPart")
    if not cloneRoot then return end
    
    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(1e10, 1e10, 1e10)
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.Parent = cloneRoot
    
    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(1e10, 1e10, 1e10)
    bodyGyro.CFrame = cloneRoot.CFrame
    bodyGyro.Parent = cloneRoot
    
    flyEnabled = true
    
    -- Управление от первого лица через камеру
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed or not flyEnabled or not isInvisible then return end
        
        local key = input.KeyCode
        local camCF = camera.CFrame
        
        if key == Enum.KeyCode.W then
            moveDirection = moveDirection + camCF.LookVector
        elseif key == Enum.KeyCode.S then
            moveDirection = moveDirection - camCF.LookVector
        elseif key == Enum.KeyCode.A then
            moveDirection = moveDirection - camCF.RightVector
        elseif key == Enum.KeyCode.D then
            moveDirection = moveDirection + camCF.RightVector
        elseif key == Enum.KeyCode.Space then
            moveDirection = moveDirection + Vector3.new(0, 1, 0)
        elseif key == Enum.KeyCode.LeftControl then
            moveDirection = moveDirection - Vector3.new(0, 1, 0)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if not flyEnabled or not isInvisible then return end
        
        local key = input.KeyCode
        local camCF = camera.CFrame
        
        if key == Enum.KeyCode.W then
            moveDirection = moveDirection - camCF.LookVector
        elseif key == Enum.KeyCode.S then
            moveDirection = moveDirection + camCF.LookVector
        elseif key == Enum.KeyCode.A then
            moveDirection = moveDirection + camCF.RightVector
        elseif key == Enum.KeyCode.D then
            moveDirection = moveDirection - camCF.RightVector
        elseif key == Enum.KeyCode.Space then
            moveDirection = moveDirection - Vector3.new(0, 1, 0)
        elseif key == Enum.KeyCode.LeftControl then
            moveDirection = moveDirection + Vector3.new(0, 1, 0)
        end
    end)
    
    -- Обновление движения
    RunService.RenderStepped:Connect(function()
        if not flyEnabled or not isInvisible then return end
        if not bodyVelocity or not bodyGyro then return end
        
        local direction = moveDirection
        if direction.Magnitude > 0 then
            direction = direction.Unit * CONFIG.flySpeed
        else
            direction = Vector3.new(0, 0, 0)
        end
        
        bodyVelocity.Velocity = direction
        bodyGyro.CFrame = camera.CFrame
    end)
end

local function disableFlightForClone()
    flyEnabled = false
    if bodyVelocity then bodyVelocity:Destroy() end
    if bodyGyro then bodyGyro:Destroy() end
    bodyVelocity = nil
    bodyGyro = nil
    moveDirection = Vector3.new(0, 0, 0)
end

-- ========== 6. ВОЗВРАЩЕНИЕ (выключение инвиза) ==========
local function returnToNormal()
    if not cloneCharacter then return end
    
    disableFlightForClone()
    
    -- Получаем позицию клона
    local cloneRoot = cloneCharacter:FindFirstChild("HumanoidRootPart")
    if cloneRoot then
        -- Телепортируем оригинальное тело к клону
        originalCharacter:SetPrimaryPartCFrame(cloneRoot.CFrame)
    end
    
    -- Делаем оригинальное тело снова видимым
    for _, part in ipairs(originalCharacter:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Transparency = 0
            part.CanCollide = true
        end
    end
    
    -- Восстанавливаем управление
    if originalHumanoid then
        originalHumanoid.WalkSpeed = 16
        originalHumanoid.JumpPower = 50
        originalHumanoid.AutoRotate = true
    end
    
    -- Переключаем камеру обратно на оригинал
    camera.CameraSubject = originalCharacter:FindFirstChild("HumanoidRootPart") or originalCharacter
    camera.CameraType = Enum.CameraType.Custom
    
    -- Уничтожаем клона
    cloneCharacter:Destroy()
    cloneCharacter = nil
end

-- ========== 7. ВКЛЮЧЕНИЕ ИНВИЗА ==========
local function enableInvis()
    if isInvisible then return end
    
    print("[INVIS] Включение...")
    
    -- Создаём клона
    cloneCharacter = createClone()
    
    -- Экипируем оружие в клона
    equipWeaponsToClone()
    
    -- Привязываем камеру к клону
    attachCameraToClone()
    
    -- Прячем оригинальное тело
    hideOriginalBody()
    
    -- Включаем полёт для клона
    enableFlightForClone()
    
    isInvisible = true
    print("[INVIS] Включён! Ты = полупрозрачный клон. V = выключить")
end

-- ========== 8. ВЫКЛЮЧЕНИЕ ИНВИЗА ==========
local function disableInvis()
    if not isInvisible then return end
    
    print("[INVIS] Выключение...")
    
    returnToNormal()
    
    isInvisible = false
    print("[INVIS] Выключён! Ты вернулся на место клона")
end

-- ========== 9. ТОГГЛ ПО КЛАВИШЕ ==========
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == CONFIG.toggleKey then
        if isInvisible then
            disableInvis()
        else
            enableInvis()
        end
    end
end)

print("========================================")
print("   INVIS SYSTEM v2 ЗАГРУЖЕН")
print("========================================")
print("Клавиша " .. tostring(CONFIG.toggleKey) .. " - вкл/выкл инвиз")
print("")
print("В режиме ИНВИЗА:")
print("  - Ты = полупрозрачный клон (видишь себя)")
print("  - Оригинальное тело спрятано далеко")
print("  - Камера привязана к клону")
