local function createButton(text, yPos, color)
    local btn = Instance.new("TextButton", mainFrame)
    btn.Size = UDim2.new(0, 240, 0, 38)
    btn.Position = UDim2.new(0, 10, 0, yPos)
    btn.BackgroundColor3 = color or Color3.fromRGB(45, 45, 55)
    btn.Text = text
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.TextSize = 14
    btn.Font = Enum.Font.Gothom
    btn.BorderSizePixel = 0
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    
    btn.MouseEnter:Connect(function()
        btn.BackgroundColor3 = Color3.fromRGB(65, 65, 75)
    end)
    btn.MouseLeave:Connect(function()
        btn.BackgroundColor3 = color or Color3.fromRGB(45, 45, 55)
    end)
    
    return btn
end

local invisBtn = createButton("🔮 TOGGLE INVIS (Z)", 45, Color3.fromRGB(80, 40, 120))
local ghostBtn = createButton("⚡ TOGGLE GHOST SPEED (B)", 95, Color3.fromRGB(40, 80, 120))
local noclipBtn = createButton("🚪 TOGGLE NOCLIP (N)", 145, Color3.fromRGB(40, 100, 60))
