speedBox.Position = UDim2.new(0, 170, 0, 245)
speedBox.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
speedBox.Text = tostring(ghostSpeed)
speedBox.TextColor3 = Color3.new(1, 1, 1)
Instance.new("UICorner", speedBox).CornerRadius = UDim.new(0, 6)

local speedLabel = Instance.new("TextLabel", mainFrame)
speedLabel.Size = UDim2.new(0, 100, 0, 25)
speedLabel.Position = UDim2.new(0, 10, 0, 245)
speedLabel.BackgroundTransparency = 1
speedLabel.Text = "Speed: " .. ghostSpeed
speedLabel.TextColor3 = Color3.new(1, 1, 1)
speedLabel.TextSize = 12
speedLabel.TextXAlignment = Enum.TextXAlignment.Left

speedBox.FocusLost:Connect(function()
    local val = tonumber(speedBox.Text)
    if val and val > 0 and val < 500 then
        ghostSpeed = val
        speedLabel.Text = "Speed: " .. ghostSpeed
        if ghostOn then
            local hum = plr.Character and plr.Character:FindFirstChildOfClass("Humanoid")
            if hum then hum.WalkSpeed = ghostSpeed end
        end
        saveData()
    else
        speedBox.Text = tostring(ghostSpeed)
    end
end)

-- ========== ОБНОВЛЕНИЕ GUI ==========
local function updateGUI()
    if invisOn then
        invisBtn.Text = "🔮 INVISIBLE: ON (Z)"
        invisBtn.BackgroundColor3 = Color3.fromRGB(60, 140, 60)
    else
        invisBtn.Text = "🔮 TOGGLE INVIS (Z)"
        invisBtn.BackgroundColor3 = Color3.fromRGB(80, 40, 120)
    end
    
    if ghostOn then
        ghostBtn.Text = "⚡ GHOST: ON (" .. ghostSpeed .. ") (B)"
        ghostBtn.BackgroundColor3 = Color3.fromRGB(60, 140, 60)
    else
        ghostBtn.Text = "⚡ TOGGLE GHOST SPEED (B)"
        ghostBtn.BackgroundColor3 = Color3.fromRGB(40, 80, 120)
    end
    
    if noclipOn then
        noclipBtn.Text = "🚪 NOCLIP: ON (N)"
        noclipBtn.BackgroundColor3 = Color3.fromRGB(60, 140, 60)
    else
        noclipBtn.Text = "🚪 TOGGLE NOCLIP (N)"
        noclipBtn.BackgroundColor3 = Color3.fromRGB(40, 100, 60)
    end
    
    if autoInvisOn then
        autoBtn.Text = "🤖 AUTO-INVIS: ON (M) [on death]"
        autoBtn.BackgroundColor3 = Color3.fromRGB(60, 140, 60)
    else
        autoBtn.Text = "🤖 AUTO-INVIS: OFF (M)"
        autoBtn.BackgroundColor3 = Color3.fromRGB(100, 60, 40)
    end
end

-- ========== ПРИВЯЗКА КНОПОК ==========
invisBtn.MouseButton1Click:Connect(toggleInvis)
ghostBtn.MouseButton1Click:Connect(toggleGhost)
noclipBtn.MouseButton1Click:Connect(toggleNoclip)
autoBtn.MouseButton1Click:Connect(toggleAutoInvis)
unloadBtn.MouseButton1Click:Connect(function()
    pcall(function() screenGui:Destroy() end)
    if noclipConnection then noclipConnection:Disconnect() end
    if ghostConnection then ghostConnection:Disconnect() end
    if deathConnection then deathConnection:Disconnect() end
    _G.InvisGhostLoaded = nil
    showNotice("Script unloaded")
end)

-- ========== ХОТКЕИ ==========
UIS.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    local key = input.KeyCode
    if key == Enum.KeyCode.Z then
        toggleInvis()
    elseif key == Enum.KeyCode.B then
        toggleGhost()
    elseif key == Enum.KeyCode.N then
        toggleNoclip()
    elseif key == Enum.KeyCode.M then
        toggleAutoInvis()
    elseif key == Enum.KeyCode.K then
        mainFrame.Visible = not mainFrame.Visible
    end
end)

-- ========== ЗАПУСК ==========
-- Настраиваем хук на смерть если персонаж уже есть
if plr.Character then
    setupDeathHook()
end

updateGUI()
showNotice("INVIS GHOST v" .. VERSION .. " | M = Auto-Invis on death")
