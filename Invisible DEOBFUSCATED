-- ПРОСТОЙ ИНВИЗ С АВТО-ВКЛЮЧЕНИЕМ ПРИ СМЕРТИ
-- Работает гарантированно

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local plr = Players.LocalPlayer

-- ========== ПЕРЕМЕННЫЕ ==========
local invisActive = false
local autoMode = false
local hidingSpot = nil

-- ========== СОЗДАНИЕ GUI ==========
local screenGui = Instance.new("ScreenGui", CoreGui)
screenGui.Name = "SimpleInvisGUI"

local mainFrame = Instance.new("Frame", screenGui)
mainFrame.Size = UDim2.new(0, 250, 0, 200)
mainFrame.Position = UDim2.new(0.5, -125, 0.5, -100)
mainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
mainFrame.BackgroundTransparency = 0.15
mainFrame.Active = true
mainFrame.Draggable = true
Instance.new("UICorner", mainFrame).CornerRadius = UDim.new(0, 12)

-- Заголовок
local title = Instance.new("TextLabel", mainFrame)
title.Size = UDim2.new(1, 0, 0, 35)
title.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
title.Text = "SIMPLE INVIS"
title.TextColor3 = Color3.new(1, 1, 1)
title.TextSize = 18
title.Font = Enum.Font.GothomBold
Instance.new("UICorner", title).CornerRadius = UDim.new(0, 12)

-- Функция создания кнопки
local function createBtn(text, y, color)
    local btn = Instance.new("TextButton", mainFrame)
    btn.Size = UDim2.new(0, 220, 0, 40)
    btn.Position = UDim2.new(0, 15, 0, y)
    btn.BackgroundColor3 = color or Color3.fromRGB(50, 50, 60)
    btn.Text = text
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.TextSize = 15
    btn.Font = Enum.Font.Gothom
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    
    btn.MouseEnter:Connect(function()
        btn.BackgroundColor3 = Color3.fromRGB(70, 70, 80)
    end)
    btn.MouseLeave:Connect(function()
        btn.BackgroundColor3 = color or Color3.fromRGB(50, 50, 60)
    end)
    return btn
end

local invisBtn = createBtn("🔮 ВКЛ/ВЫКЛ ИНВИЗ (Z)", 45, Color3.fromRGB(80, 40, 120))
local autoBtn = createBtn("🤖 АВТО-ИНВИЗ: ВЫКЛ (X)", 95, Color3.fromRGB(100, 60, 40))
local unloadBtn = createBtn("❌ ВЫГРУЗИТЬ", 145, Color3.fromRGB(120, 40, 40))

-- Статус
local statusLabel = Instance.new("TextLabel", mainFrame)
statusLabel.Size = UDim2.new(1, 0, 0, 25)
statusLabel.Position = UDim2.new(0, 0, 1, -30)
statusLabel.BackgroundTransparency = 1
statusLabel.Text = "Статус: Ожидание"
statusLabel.TextColor3 = Color3.new(1, 1, 1)
statusLabel.TextSize = 12

-- ========== ФУНКЦИЯ УВЕДОМЛЕНИЙ ==========
local function notify(msg, isError)
    pcall(function()
        if CoreGui:FindFirstChild("Notice") then CoreGui.Notice:Destroy() end
        local g = Instance.new("ScreenGui", CoreGui)
        g.Name = "Notice"
        local f = Instance.new("Frame", g)
        f.Size = UDim2.new(0, 300, 0, 40)
        f.Position = UDim2.new(0.5, -150, 0, 80)
        f.BackgroundColor3 = isError and Color3.fromRGB(150, 0, 0) or Color3.fromRGB(0, 100, 0)
        Instance.new("UICorner", f).CornerRadius = UDim.new(0, 10)
        local l = Instance.new("TextLabel", f)
        l.Size = UDim2.new(1, 0, 1, 0)
        l.BackgroundTransparency = 1
        l.Text = msg
        l.TextColor3 = Color3.new(1, 1, 1)
        l.TextSize = 14
        task.delay(2, function() pcall(function() g:Destroy() end) end)
    end)
end

-- ========== ОСНОВНЫЕ ФУНКЦИИ ==========
local function makeTransparent(char, val)
    if not char then return end
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Transparency = val
        end
    end
end

local function hideBody()
    local char = plr.Character
    if not char then return false end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then
        hidingSpot = hrp.CFrame
        -- Улетаем вверх
        char:SetPrimaryPartCFrame(CFrame.new(0, 100000, 0))
        -- Замораживаем
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Anchored = true
            end
        end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.PlatformStand = true
        end
        return true
    end
    return false
end

local function returnBody()
    local char = plr.Character
    if not char then return end
    
    if hidingSpot then
        char:SetPrimaryPartCFrame(hidingSpot)
    end
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Anchored = false
            part.Transparency = 0
        end
    end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.PlatformStand = false
    end
end

local function enableInvis()
    if invisActive then return end
    local char = plr.Character
    if not char then
        notify("Нет персонажа!", true)
        return
    end
    
    makeTransparent(char, 0.7)
    if hideBody() then
        invisActive = true
        statusLabel.Text = "Статус: ИНВИЗ ВКЛ"
        statusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
        invisBtn.BackgroundColor3 = Color3.fromRGB(60, 140, 60)
        invisBtn.Text = "🔮 ИНВИЗ: ВКЛ (Z)"
        notify("✅ ИНВИЗ ВКЛЮЧЁН")
    end
end

local function disableInvis()
    if not invisActive then return end
    local char = plr.Character
    if not char then
        invisActive = false
        return
    end
    
    returnBody()
    makeTransparent(char, 0)
    invisActive = false
    statusLabel.Text = "Статус: ИНВИЗ ВЫКЛ"
    statusLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    invisBtn.BackgroundColor3 = Color3.fromRGB(80, 40, 120)
    invisBtn.Text = "🔮 ВКЛ/ВЫКЛ ИНВИЗ (Z)"
    notify("❌ ИНВИЗ ВЫКЛЮЧЁН")
end

local function toggleInvis()
    if invisActive then
        disableInvis()
    else
        enableInvis()
    end
end

-- ========== АВТО-ИНВИЗ ПРИ СМЕРТИ ==========
local deathConn = nil
local respawnConn = nil
local pendingRespawn = false

local function onCharacterAdded(newChar)
    task.wait(0.5) -- Ждём загрузки
    
    -- Если был запланирован респавн (умерли) - включаем инвиз
    if autoMode and pendingRespawn then
        task.wait(0.3)
        enableInvis()
        pendingRespawn = false
        notify("🤖 АВТО-ИНВИЗ: Включён после смерти")
    end
    
    -- Подписываемся на смерть нового персонажа
    local hum = newChar:FindFirstChildOfClass("Humanoid")
    if hum and deathConn then
        deathConn:Disconnect()
        deathConn = hum.Died:Connect(function()
            if autoMode then
                pendingRespawn = true
                notify("💀 Вы умерли! Инвиз включится при респавне")
                -- Если инвиз был включён - выключаем
                if invisActive then
                    disableInvis()
                end
            end
        end)
    end
end

-- Подписываемся на появление персонажа
plr.CharacterAdded:Connect(onCharacterAdded)

-- Если персонаж уже есть - настраиваем
if plr.Character then
    task.wait(0.5)
    local hum = plr.Character:FindFirstChildOfClass("Humanoid")
    if hum then
        deathConn = hum.Died:Connect(function()
            if autoMode then
                pendingRespawn = true
                notify("💀 Вы умерли! Инвиз включится при респавне")
                if invisActive then
                    disableInvis()
                end
            end
        end)
    end
end

-- ========== ВКЛ/ВЫКЛ АВТО-РЕЖИМА ==========
local function toggleAutoMode()
    autoMode = not autoMode
    
    if autoMode then
        autoBtn.Text = "🤖 АВТО-ИНВИЗ: ВКЛ (X)"
        autoBtn.BackgroundColor3 = Color3.fromRGB(60, 140, 60)
        notify("🤖 АВТО-ИНВИЗ ВКЛЮЧЁН (включится после смерти)")
        statusLabel.Text = "Статус: АВТО-ИНВИЗ ВКЛ"
    else
        autoBtn.Text = "🤖 АВТО-ИНВИЗ: ВЫКЛ (X)"
        autoBtn.BackgroundColor3 = Color3.fromRGB(100, 60, 40)
        pendingRespawn = false
        notify("🤖 АВТО-ИНВИЗ ВЫКЛЮЧЁН")
        statusLabel.Text = "Статус: АВТО-ИНВИЗ ВЫКЛ"
    end
end

-- ========== ВЫГРУЗКА ==========
local function unload()
    if deathConn then deathConn:Disconnect() end
    pcall(function() screenGui:Destroy() end)
    if invisActive then
        returnBody()
        local char = plr.Character
        if char then
            makeTransparent(char, 0)
        end
    end
    _G.SimpleInvisLoaded = nil
    notify("Скрипт выгружен")
end

-- ========== ПРИВЯЗКА КНОПОК ==========
invisBtn.MouseButton1Click:Connect(toggleInvis)
autoBtn.MouseButton1Click:Connect(toggleAutoMode)
unloadBtn.MouseButton1Click:Connect(unload)

-- ========== ХОТКЕИ ==========
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.Z then
        toggleInvis()
    elseif input.KeyCode == Enum.KeyCode.X then
        toggleAutoMode()
    end
end)

notify("Скрипт загружен! Z - Инвиз | X - Авто-режим")
