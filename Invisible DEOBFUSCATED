local SETTINGS_FOLDER = "FeInvisibleOld"
local SETTINGS_FILE = SETTINGS_FOLDER .. "/ghostspeed.txt"
local AUTO_SETTINGS_FILE = SETTINGS_FOLDER .. "/autosettings.txt"

local function saveSpeed(speed)
    if isfolder and makefolder and writefile then
        if not isfolder(SETTINGS_FOLDER) then
            makefolder(SETTINGS_FOLDER)
        end
        writefile(SETTINGS_FILE, tostring(speed))
    end
end

local function loadSpeed()
    if isfile and readfile and isfile(SETTINGS_FILE) then
        local val = tonumber(readfile(SETTINGS_FILE))
        if val then
            return val
        end
    end
    return 50
end

local function saveAutoSettings(enabled, delay)
    if isfolder and makefolder and writefile then
        if not isfolder(SETTINGS_FOLDER) then
            makefolder(SETTINGS_FOLDER)
        end
        writefile(AUTO_SETTINGS_FILE, enabled .. "," .. delay)
    end
end

local function loadAutoSettings()
    if isfile and readfile and isfile(AUTO_SETTINGS_FILE) then
        local data = readfile(AUTO_SETTINGS_FILE)
        local parts = {}
        for part in string.gmatch(data, "[^,]+") do
            table.insert(parts, part)
        end
        if #parts >= 2 then
            return parts[1] == "true", tonumber(parts[2]) or 3
        end
    end
    return false, 3
end

