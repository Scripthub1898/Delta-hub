--[[
	INVIS GHOST v4.0 - AUTO INVIS ON DEATH/RESPAWN
	Авто-инвиз включается когда ты умираешь и после респавна
]]

local VERSION = 4.0

if _G.InvisGhostLoaded and _G.InvisGhostLoaded >= VERSION then
    return
end
_G.InvisGhostLoaded = VERSION

local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local plr = Players.LocalPlayer

-- ========== ПЕРЕМЕННЫЕ ==========
local invisOn = false
local ghostOn = false
local noclipOn = false
local autoInvisOn = false  -- Авто-инвиз при смерти
local ghostSpeed = 50
local hidingPlace = nil
local noclipConnection = nil
local ghostConnection = nil
local deathConnection = nil
local respawnConnection = nil
local isRespawning = false

-- ========== ФУНКЦИИ СОХРАНЕНИЯ ==========
local function saveData()
    pcall(function()
        if not isfolder then return end
        if not isfolder("InvisGhostData") then makefolder("InvisGhostData") end
        writefile("InvisGhostData/settings.txt", ghostSpeed .. "," .. tostring(autoInvisOn))
    end)
end

local function loadData()
    pcall(function()
        if isfile and isfile("InvisGhostData/settings.txt") then
            local data = readfile("InvisGhostData/settings.txt")
            local parts = {}
            for part in string.gmatch(data, "[^,]+") do
                table.insert(parts, part)
            end
            if #parts >= 1 then
                ghostSpeed = tonumber(parts[1]) or 50
            end
            if #parts >= 2 then
                autoInvisOn = parts[2] == "true"
            end
        end
    end)
end

loadData()

-- ========== УВЕДОМЛЕНИЯ ==========
local function showNotice(text, isError)
    pcall(function()
        if CoreGui:FindFirstChild("InvisNotice") then
            CoreGui.InvisNotice:Destroy()
        end
        local gui = Instance.new("ScreenGui", CoreGui)
        gui.Name = "InvisNotice"
        gui.ResetOnSpawn = false
        local frame = Instance.new("Frame", gui)
        frame.Size = UDim2.new(0, 350, 0, 45)
        frame.Position = UDim2.new(0.5, -175, 0, 60)
        frame.BackgroundColor3 = isError and Color3.fromRGB(150, 30, 30) or Color3.fromRGB(30, 30, 40)
        frame.BackgroundTransparency = 0.15
        Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 10)
        local label = Instance.new("TextLabel", frame)
        label.Size = UDim2.new(1, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.Text = text
        label.TextColor3 = Color3.new(1, 1, 1)
        label.TextSize = 16
        label.Font = Enum.Font.Gothom
        task.delay(2.5, function()
            pcall(function() gui:Destroy() end)
        end)
    end)
end

-- ========== ОСНОВНАЯ ФУНКЦИЯ ИНВИЗА ==========
local function setTransparency(char, val)
    if not char then return end
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            part.Transparency = val
        end
    end
end

local function toggleInvis(silent)
    local char = plr.Character
    if not char then
        if not silent then showNotice("Character not found!", true) end
        return
    end
    
    invisOn = not invisOn
    
    if invisOn then
        -- Делаем полупрозрачным
        setTransparency(char, 0.7)
        
        -- Сохраняем позицию и прячем тело
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            hidingPlace = hrp.CFrame
            char:SetPrimaryPartCFrame(CFrame.new(0, 10000, 0))
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.Anchored = true
                end
            end
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                hum.PlatformStand = true
            end
        end
        if not silent then showNotice("🔮 INVISIBLE ON") end
    else
        -- Возвращаем тело
        if hidingPlace then
            char:SetPrimaryPartCFrame(hidingPlace)
        end
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Anchored = false
                part.Transparency = 0
            end
        end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.PlatformStand = false
        end
        if not silent then showNotice("👁️ INVISIBLE OFF") end
    end
    
    updateGUI()
end

-- Принудительное включение инвиза (без переключения)
local function forceInvisOn()
    if invisOn then return end
    local char = plr.Character
    if not char then return end
    
    invisOn = true
    setTransparency(char, 0.7)
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then
        hidingPlace = hrp.CFrame
        char:SetPrimaryPartCFrame(CFrame.new(0, 10000, 0))
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Anchored = true
            end
        end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.PlatformStand = true
        end
    end
    showNotice("🤖 AUTO-INVIS: Activated (death/respawn)")
    updateGUI()
end

-- Принудительное выключение инвиза
local function forceInvisOff()
    if not invisOn then return end
    local char = plr.Character
    if not char then return end
    
    invisOn = false
    if hidingPlace then
        char:SetPrimaryPartCFrame(hidingPlace)
    end
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Anchored = false
            part.Transparency = 0
        end
    end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.PlatformStand = false
    end
    updateGUI()
end

-- ========== СИСТЕМА АВТО-ИНВИЗА ПРИ СМЕРТИ ==========
local function setupDeathHook()
    -- Отключаем старые подключения
    if deathConnection then deathConnection:Disconnect() end
    if respawnConnection then respawnConnection:Disconnect() end
    
    local char = plr.Character
    if not char then return end
    
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    
    -- Следим за смертью
    deathConnection = hum.Died:Connect(function()
        if autoInvisOn then
            showNotice("💀 You died! Auto-Invis will activate on respawn...")
            isRespawning = true
            
            -- Если инвиз был включен, выключаем (чтобы после респавна включить заново)
            if invisOn then
                forceInvisOff()
            end
        end
    end)
end

-- Следим за респавном (появление нового персонажа)
plr.CharacterAdded:Connect(function(newChar)
    task.wait(0.5) -- Ждём пока персонаж загрузится
    
    -- Настраиваем хук на смерть для нового персонажа
    local hum = newChar:FindFirstChildOfClass("Humanoid")
    if hum then
        if deathConnection then deathConnection:Disconnect() end
        deathConnection = hum.Died:Connect(function()
            if autoInvisOn then
                showNotice("💀 You died! Auto-Invis on respawn...")
                isRespawning = true
                if invisOn then
                    forceInvisOff()
                end
            end
        end)
    end
    
    -- Если авто-инвиз включен и мы умерли - включаем инвиз при респавне
    if autoInvisOn and isRespawning then
        task.wait(0.3)
        forceInvisOn()
        isRespawning = false
    end
    
    -- Восстанавливаем Ghost Speed если включен
    if ghostOn then
        task.wait(0.2)
        local newHum = newChar:FindFirstChildOfClass("Humanoid")
        if newHum then
            newHum.WalkSpeed = ghostSpeed
        end
    end
    
    setupMovementHook()
end)

-- ========== ОСТАЛЬНЫЕ ФУНКЦИИ ==========
local function toggleGhost()
    local hum = plr.Character and plr.Character:FindFirstChildOfClass("Humanoid")
    ghostOn = not ghostOn
    
    if ghostOn then
        if hum then hum.WalkSpeed = ghostSpeed end
        if ghostConnection then ghostConnection:Disconnect() end
        ghostConnection = RunService.Stepped:Connect(function()
            local h = plr.Character and plr.Character:FindFirstChildOfClass("Humanoid")
            if h and h.WalkSpeed ~= ghostSpeed then
                h.WalkSpeed = ghostSpeed
            end
        end)
        showNotice("⚡ GHOST SPEED: " .. ghostSpeed)
    else
        if ghostConnection then ghostConnection:Disconnect() end
        if hum then hum.WalkSpeed = 16 end
        showNotice("🐢 GHOST SPEED: OFF")
    end
    updateGUI()
end

local function toggleNoclip()
    noclipOn = not noclipOn
    
    if noclipOn then
        if noclipConnection then noclipConnection:Disconnect() end
        noclipConnection = RunService.Stepped:Connect(function()
            local char = plr.Character
            if char then
                for _, part in pairs(char:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = false
                    end
                end
            end
        end)
        showNotice("🚪 NOCLIP: ON")
    else
        if noclipConnection then noclipConnection:Disconnect() end
        local char = plr.Character
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = true
                end
            end
        end
        showNotice("🚫 NOCLIP: OFF")
    end
    updateGUI()
end

local function toggleAutoInvis()
    autoInvisOn = not autoInvisOn
    saveData()
    
    if autoInvisOn then
        showNotice("🤖 AUTO-INVIS: ON (activates on death/respawn)")
        -- Если персонаж уже есть, настраиваем хук
        if plr.Character then
            setupDeathHook()
        end
    else
        showNotice("🤖 AUTO-INVIS: OFF")
        if deathConnection then deathConnection:Disconnect() end
        isRespawning = false
    end
    updateGUI()
end

-- Хук на движение (для сброса таймера не нужен больше, но оставим для других функций)
local function setupMovementHook()
    -- Не нужно для авто-инвиза при смерти, но оставим для совместимости
end

