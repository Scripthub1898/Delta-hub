local function setTransparency(char, val)
    for _, p in ipairs(char:GetDescendants()) do
        if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then
            p.Transparency = val
        end
    end
end

local function toggleInvis()
    invisOn = not invisOn
    local char = plr.Character
    if char then
        if invisOn then
            setTransparency(char, 0.5)
            local savedpos = char.HumanoidRootPart.CFrame
            task.wait()
            char:MoveTo(Vector3.new(-25.95, 84, 3537.55))
            task.wait(0.15)
            local Seat = Instance.new("Seat", workspace)
            Seat.Anchored = false
            Seat.CanCollide = false
            Seat.Name = "invischair"
            Seat.Transparency = 1
            Seat.Position = Vector3.new(-25.95, 84, 3537.55)
            local Weld = Instance.new("Weld", Seat)
            Weld.Part0 = Seat
            Weld.Part1 = char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
            Seat.CFrame = savedpos
            showNotice("Invisibility Enabled")
        else
            setTransparency(char, 0)
            if workspace:FindFirstChild("invischair") then
                workspace.invischair:Destroy()
            end
            showNotice("Invisibility Disabled")
        end
    end
end

-- ========== СИСТЕМА АВТО-ИНВИЗА ==========
local function startAutoInvisTimer()
    if autoInvisTimerConn then
        autoInvisTimerConn:Disconnect()
        autoInvisTimerConn = nil
    end
    
    autoInvisTimerConn = RunService.Stepped:Connect(function()
        if not autoInvisOn then return end
        if invisOn then return end  -- Уже в инвизе
        
        local currentTime = tick()
        local char = plr.Character
        local isMoving = false
        
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local hum = char:FindFirstChildOfClass("Humanoid")
            
            if hrp and hrp.AssemblyLinearVelocity.Magnitude > 1 then
                isMoving = true
                lastMovementTime = currentTime
            elseif hum and hum.Sit then
                isMoving = true
                lastMovementTime = currentTime
            end
        end
        
        -- Если не двигаемся дольше задержки - включаем инвиз
        if not isMoving and (currentTime - lastMovementTime) >= autoInvisDelay then
            if not invisOn then
                toggleInvis()
                wasInvisBeforeAuto = true
                showNotice("🤖 AUTO-INVIS: Activated (idle for " .. autoInvisDelay .. " sec)")
            end
        end
    end)
end

local function stopAutoInvisTimer()
    if autoInvisTimerConn then
        autoInvisTimerConn:Disconnect()
        autoInvisTimerConn = nil
    end
end

local function updateAutoButtonText()
    if autoInvisOn then
        autoBtn.Text = "Auto-Invis: ON 🤖 (" .. autoInvisDelay .. "s)"
        autoBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 0)
        startAutoInvisTimer()
    else
        autoBtn.Text = "Auto-Invis: OFF 🤖"
        autoBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        stopAutoInvisTimer()
    end
end

local function toggleAutoInvis()
    autoInvisOn = not autoInvisOn
    saveAutoSettings(autoInvisOn, autoInvisDelay)
    updateAutoButtonText()
    
    if not autoInvisOn and wasInvisBeforeAuto and invisOn then
        -- Если авто-инвиз выключен и мы были в инвизе от авто - выключаем
        toggleInvis()
        wasInvisBeforeAuto = false
        showNotice("🤖 AUTO-INVIS: Disabled")
    elseif autoInvisOn then
        lastMovementTime = tick()
        showNotice("🤖 AUTO-INVIS: Enabled (" .. autoInvisDelay .. " sec idle)")
    end
end

local function setAutoDelay(delay)
    autoInvisDelay = math.clamp(delay, 1, 30)
    saveAutoSettings(autoInvisOn, autoInvisDelay)
    updateAutoButtonText()
    showNotice("🤖 Auto-Invis delay set to " .. autoInvisDelay .. " seconds")
end

-- Хук на движение для сброса таймера при движении
local function setupMovementHook()
    local char = plr.Character
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp:GetPropertyChangedSignal("AssemblyLinearVelocity"):Connect(function()
                if autoInvisOn and invisOn and wasInvisBeforeAuto then
                    if hrp.AssemblyLinearVelocity.Magnitude > 1 then
                        -- Начали двигаться - выключаем инвиз
                        toggleInvis()
                        wasInvisBeforeAuto = false
                        lastMovementTime = tick()
                        showNotice("🤖 AUTO-INVIS: Deactivated (movement detected)")
                    end
                end
            end)
        end
    end
end

-- Подписываемся на добавление персонажа
plr.CharacterAdded:Connect(function()
    setupMovementHook()
    lastMovementTime = tick()
end)

